# MongoDB connection string (MongoDB Atlas → Connect → Drivers → copy full URI)
# Replace the hostname with YOUR cluster address, e.g. cluster0.abc123.mongodb.net
# (Do NOT leave the placeholder "cluster.mongodb.net" — it will not resolve.)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/neurora?retryWrites=true&w=majority

# OpenAI API key (https://platform.openai.com/api-keys) — required for check-in AI analysis
OPENAI_API_KEY=sk-your-real-openai-key-here

# OpenAI model (gpt-4o-mini recommended for cost/quality balance)
OPENAI_MODEL=gpt-4o-mini

# 32-byte hex key for AES-256 journal encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# App URL (used for metadata / deployment)
NEXT_PUBLIC_APP_URL=http://localhost:3000
