# MongoDB connection string (MongoDB Atlas or local)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mindmate-ai?retryWrites=true&w=majority

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here

# OpenAI model (gpt-4o-mini recommended for cost/quality balance)
OPENAI_MODEL=gpt-4o-mini

# 32-byte hex key for AES-256 journal encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=your-64-char-hex-encryption-key-here

# App URL (used for metadata / deployment)
NEXT_PUBLIC_APP_URL=http://localhost:3000
